# ── Server ────────────────────────────────────────────────────
PORT=9000

# ── Routing table (per-chargeBoxId) ──────────────────────────
# Path to the JSON routing table. Each charge point is matched by
# its chargeBoxId; unmatched ids fall back to the "default" route.
# See routes.example.json for the schema.
ROUTES_FILE=./routes.json

# ── Logging ───────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info
